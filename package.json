{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "start": "node dist/server.js",
    "build": "vite build && npm run build:server",
    "build:server": "esbuild server.ts --bundle --platform=node --target=node22 --outfile=dist/server.js --format=esm --packages=external --loader:.json=json",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "postinstall": "prisma generate",
    "cap:sync": "npx cap sync",
    "cap:open": "npx cap open android",
    "cap:build": "npx vite build && npx cap sync"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
