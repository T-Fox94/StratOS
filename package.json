    "prisma": "^6.1.0",
    "react": "^19.0.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.7.0",
    "shadcn": "^4.0.3",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
